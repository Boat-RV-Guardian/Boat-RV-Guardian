rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isValidClaim(vid) {
      let inv = get(/databases/$(database)/documents/invites/$(request.resource.data.lastClaimInviteId)).data;
      return request.auth != null
        && !(request.auth.uid in resource.data.allowedUsers)
        && request.auth.uid in request.resource.data.allowedUsers
        && inv.vehicleId == vid
        && inv.status == 'pending'
        && inv.inviteeEmail == request.auth.token.email
        && request.resource.data.members[request.auth.uid].role == inv.role;
    }

    // Operator admin console (Task 12): `admin: true` is a Firebase custom claim, granted out-of-band
    // by website-boatrvguardian/scripts/grant-admin.mjs. Operators may list/read every vehicle and
    // change ONLY the tier fields. Client gating in the console is UX; THIS is the enforcement.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // --- Role-aware vehicle-update helpers (SEC-1) --------------------------------------------------
    // Previously ANY member (incl. a `monitor`) could write EVERY field of the vehicle doc, so a member
    // could rewrite their own `members` role to admin, seize `owner`, forge `tier`, or add other users to
    // `allowedUsers` — client-side, and thereby also defeat the worker's server-side role/tier checks
    // (which read those same fields). These helpers restrict a plain member to config-only writes while
    // leaving every legitimate flow working (see firestore-tests/ for the exhaustive allow/deny suite).

    // The caller is a member of THIS vehicle (in allowedUsers).
    function isMember() {
      return request.auth != null && request.auth.uid in resource.data.allowedUsers;
    }

    // The caller is this vehicle's admin/owner: the `owner` uid, OR an `admin`-role member, OR a legacy
    // vehicle that predates the `members` map (getMyRole treats those members as admin). Admins/owners
    // keep full write access (transfer ownership, add/remove members, set tier via coupon, etc.).
    function isVehicleAdmin() {
      return isMember()
        && ( resource.data.owner == request.auth.uid
          || !('members' in resource.data)
          || ( request.auth.uid in resource.data.members
               && resource.data.members[request.auth.uid].role == 'admin' ) );
    }

    // Privileged fields a plain (non-admin) member must never change: role/ownership/entitlement and the
    // access-grant list. A normal config sync write does NOT hit these — updateVehicleConfig appends
    // `allowedUsers: arrayUnion(self)`, which is a no-op for an existing member and so is absent from
    // affectedKeys(). `tier` stays admin/coupon-owner-only (mock billing); the worker writes tier/trial
    // via the Admin SDK, which bypasses rules entirely.
    function changesPrivilegedFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['owner', 'members', 'tier', 'trialEndsAt', 'allowedUsers']);
    }

    // A member removing ONLY themselves (leaveVehicle): drops self from allowedUsers + their own members
    // entry and touches nothing else. Always allowed for the departing member.
    function isSelfLeave() {
      return isMember()
        && !(request.auth.uid in request.resource.data.allowedUsers)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['allowedUsers', 'members']);
    }
    // -----------------------------------------------------------------------------------------------

    match /vehicles/{vid} {
      // `resource == null` allows reading a not-yet-created doc (returns exists:false) instead of
      // denying it — without this, a brand-new vehicle's onSnapshot errors and the create path never runs.
      allow read:   if (request.auth != null && (resource == null || request.auth.uid in resource.data.allowedUsers))
                    || isAdmin();
      allow create: if request.auth != null && request.auth.uid in request.resource.data.allowedUsers;
      allow update: if isValidClaim(vid)
                    // A member may write config freely, an admin/owner may write anything, and any member
                    // may remove themselves — but a non-admin member may NOT touch privileged fields.
                    || (isMember() && (isVehicleAdmin() || isSelfLeave() || !changesPrivilegedFields()))
                    // Operators may set tier/trial AND remove a member (members/allowedUsers) — the
                    // latter backs the admin console's "delete user" (drop them from shared vehicles).
                    || (isAdmin()
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tier', 'trialEndsAt', 'members', 'allowedUsers', 'owner']));
      // Operators may delete any vehicle (admin console). A SOLE owner may delete their own vehicle —
      // this is what lets the consumer account-deletion hard-delete the boats you solely own.
      allow delete: if isAdmin()
                    || (request.auth != null
                        && request.auth.uid in resource.data.allowedUsers
                        && resource.data.allowedUsers.size() == 1);

      match /history/{histId} {
        // History docs (monthly usage/events rollups) carry no allowedUsers of their own —
        // authorize against the PARENT vehicle's allowedUsers, like sensorState below.
        allow read, write: if request.auth != null
                           && request.auth.uid in get(/databases/$(database)/documents/vehicles/$(vid)).data.allowedUsers;
      }

      // Worker-cached last sensor event (battery sensors). Worker writes via admin (bypasses rules).
      // Operators (Task 12) may read sensorState for the admin console's Operations view.
      match /sensorState/{sid} {
        allow read:  if (request.auth != null
                        && request.auth.uid in get(/databases/$(database)/documents/vehicles/$(vid)).data.allowedUsers)
                     || isAdmin();
        allow write: if false;
      }
    }

    match /invites/{inviteId} {
      allow read:   if request.auth != null && (resource.data.inviteeEmail == request.auth.token.email
                       || resource.data.invitedBy == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.invitedBy == request.auth.uid
                       && request.auth.uid in get(/databases/$(database)/documents/vehicles/$(request.resource.data.vehicleId)).data.allowedUsers;
      allow update: if request.auth != null && (resource.data.inviteeEmail == request.auth.token.email
                       || resource.data.invitedBy == request.auth.uid);
      allow delete: if request.auth != null && resource.data.invitedBy == request.auth.uid;
    }

    match /users/{uid} {
      // Operators (Task 12) may READ user docs for the admin console's Users view (trial history +
      // FCM-token presence). Writes stay self-only.
      allow read:   if (request.auth != null && request.auth.uid == uid) || isAdmin();
      // Self-writes only, and the client may NOT write `trialsUsed` (SEC-13): it is the trial
      // anti-abuse ledger, written ONLY by the worker via the Admin SDK. Letting a user clear their own
      // `trialsUsed` would let them re-farm the free Basic trial. No client flow writes it (config,
      // fcmToken, and displayName are the only self-writes).
      allow create: if request.auth != null && request.auth.uid == uid
                    && !('trialsUsed' in request.resource.data);
      allow update: if request.auth != null && request.auth.uid == uid
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['trialsUsed']);
      // Operators may delete a user's doc (admin console "delete user"). NOTE: this removes the
      // Firestore profile only — deleting the Firebase Auth account needs the privileged backend.
      allow delete: if (request.auth != null && request.auth.uid == uid) || isAdmin();
    }

    // Operator admin audit trail (Task 12): append-only, operators only.
    match /adminAudit/{id} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
