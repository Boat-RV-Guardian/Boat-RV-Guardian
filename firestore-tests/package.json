{
  "name": "brvg-firestore-rules-tests",
  "private": true,
  "version": "1.0.0",
  "description": "Firestore security-rules unit tests (emulator-backed). Verifies firestore.rules.",
  "type": "module",
  "scripts": {
    "test": "firebase emulators:exec --only firestore \"vitest run\"",
    "test:watch": "firebase emulators:exec --only firestore \"vitest\""
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "firebase": "^11.0.0",
    "firebase-tools": "^13.0.0",
    "vitest": "^2.1.0"
  }
}
