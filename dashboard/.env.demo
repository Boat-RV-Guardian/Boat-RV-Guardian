# Loaded only by `vite --mode demo` / `vite build --mode demo` (the demo.boatrvguardian.com build).
# VITE_DEMO=1 turns on the public no-login showcase: fake fleet + simulated telemetry through the real
# widgets. In every other mode this file is not loaded, VITE_DEMO is undefined, and isDemoMode() folds
# to false so the demo code is stripped from the production web app and the native apps.
VITE_DEMO=1
